# Gmail API OAuth credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GMAIL_USER_EMAIL=your-email@gmail.com

# Gmail watch / Pub/Sub
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC=projects/your-gcp-project-id/topics/your-topic
PUBSUB_VERIFICATION_TOKEN=your-shared-token
PUBSUB_PUSH_AUDIENCE=https://your-backend-host/api/notifications

# Neon database
NEON_DATABASE_URL=postgresql://user:password@host:5432/database

# App settings
PORT=4000
