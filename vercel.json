{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/backend/app.js"
    },
    {
      "src": "^/web/?$",
      "dest": "/globalgames/index.html"
    },
    {
      "src": "^/web/(.*)$",
      "dest": "/globalgames/$1"
    },
    {
      "src": "^/admin/assets/(.*)$",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "^/admin(?:/.*)?$",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
